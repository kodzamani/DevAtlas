<UserControl x:Class="DevAtlas.Controls.ScanningOverlay"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:DevAtlas.Services"
             Background="#CC000000"
             IsVisible="False">

    <UserControl.Styles>
        <Style Selector="Ellipse.LoadingSpinner">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Stroke" Value="{DynamicResource Accent.Primary}"/>
            <Setter Property="StrokeThickness" Value="4"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        </Style>
    </UserControl.Styles>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="{DynamicResource Bg.Card}" CornerRadius="16" Padding="50,40"
                BorderBrush="{DynamicResource Border.Normal}" BorderThickness="1"
                BoxShadow="0 0 20 0 #26000000">

            <StackPanel Width="360">
              
                <!-- Status -->
                <TextBlock x:Name="StatusText" 
                           Text="{Binding [ScanStarting], Source={x:Static svc:LanguageManager.Instance}, Mode=OneWay}"
                           FontSize="13" Foreground="{DynamicResource Text.Tertiary}"
                           HorizontalAlignment="Center" Margin="0,0,0,24" TextWrapping="Wrap" TextAlignment="Center"/>


                <!-- Current path -->
                <Border Background="{DynamicResource Bg.Muted}" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F4C1;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CurrentPathText" 
                                   Grid.Column="1"
                                   Text="{Binding [ScanInitializing], Source={x:Static svc:LanguageManager.Instance}, Mode=OneWay}"
                                   FontSize="11" Foreground="{DynamicResource Text.Tertiary}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Progress bar -->
                <Border Background="{DynamicResource Border.Normal}" Height="8" CornerRadius="4" Margin="0,0,0,20">
                    <Border x:Name="ProgressBar" 
                            Background="{DynamicResource Accent.Primary}" 
                            Height="8" 
                            CornerRadius="4"
                            Width="0"
                            HorizontalAlignment="Left">
                        <Border.Styles>
                            <Style Selector="Border#ProgressBar">
                                <Style.Animations>
                                    <Animation Duration="0:0:0.8"
                                               IterationCount="INFINITE"
                                               PlaybackDirection="Alternate">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Opacity" Value="1"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Border.Styles>
                    </Border>
                </Border>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
